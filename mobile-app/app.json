{
  "expo": {
    "name": "HyperServe",
    "slug": "hyperserve-customer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#8B5CF6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hyperserve.customer"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#8B5CF6"
      },
      "package": "com.hyperserve.customer",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "hyperserve-customer"
      }
    }
  }
}
