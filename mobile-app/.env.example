# HyperServe Customer App - Environment Configuration
# Copy this file to .env and update with your production values

# Production Backend URL (Emergent Hosted)
EXPO_PUBLIC_BACKEND_URL=https://hyperserve-food-mvp.emergent.host

# Expo Configuration
EXPO_TUNNEL_SUBDOMAIN=hyperserve-food-mvp
EXPO_PACKAGER_HOSTNAME=https://hyperserve-food-mvp.emergent.host
EXPO_USE_FAST_RESOLVER="1"
EXPO_PACKAGER_PROXY_URL=https://hyperserve-food-mvp.ngrok.io

# Notes:
# - EXPO_PUBLIC_BACKEND_URL: Your production backend API URL
# - This should match your deployed admin panel backend
# - All mobile API calls will be made to this URL
